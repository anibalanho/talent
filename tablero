<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tablero de operaciones</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #F7F6F3;
  --surface: #FFFFFF;
  --surface2: #F0EEE9;
  --border: rgba(0,0,0,0.09);
  --border-strong: rgba(0,0,0,0.16);
  --text: #1A1917;
  --text-2: #6B6860;
  --text-3: #A09E99;
  --accent: #1A1917;
  --green: #2D6A4F; --green-bg: #E8F5EE; --green-text: #1B4D38;
  --amber: #92520A; --amber-bg: #FDF0DC; --amber-text: #6B3B07;
  --red: #A32D2D; --red-bg: #FCEAEA; --red-text: #7A2020;
  --blue: #1A4F8A; --blue-bg: #E8F0FB; --blue-text: #123A6A;
  --gray-bg: #EEECE8; --gray-text: #5A5855;
  --radius: 10px;
  --radius-sm: 6px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);font-size:14px;line-height:1.5;min-height:100vh}
.layout{display:grid;grid-template-columns:220px 1fr;min-height:100vh}

/* Sidebar */
.sidebar{background:var(--surface);border-right:1px solid var(--border);padding:24px 0;display:flex;flex-direction:column;position:sticky;top:0;height:100vh}
.logo{padding:0 20px 24px;border-bottom:1px solid var(--border);margin-bottom:20px}
.logo-name{font-size:13px;font-weight:500;color:var(--text)}
.logo-sub{font-size:11px;color:var(--text-3);margin-top:2px}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 20px;cursor:pointer;font-size:13px;color:var(--text-2);transition:all 0.15s;border-left:2px solid transparent}
.nav-item:hover{background:var(--surface2);color:var(--text)}
.nav-item.active{background:var(--surface2);color:var(--text);font-weight:500;border-left:2px solid var(--text)}
.nav-icon{width:16px;height:16px;opacity:0.6}
.nav-item.active .nav-icon{opacity:1}
.nav-section{font-size:10px;font-weight:500;letter-spacing:0.08em;color:var(--text-3);padding:16px 20px 6px;text-transform:uppercase}
.sidebar-footer{margin-top:auto;padding:16px 20px;border-top:1px solid var(--border)}
.clock-display{font-family:'DM Mono',monospace;font-size:12px;color:var(--text-3)}

/* Main */
.main{padding:32px 36px;overflow-x:hidden}
.page-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:28px}
.page-title{font-size:22px;font-weight:400;letter-spacing:-0.02em;color:var(--text)}
.page-sub{font-size:13px;color:var(--text-3);margin-top:3px}

/* Metrics */
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:32px}
.metric{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px}
.metric-label{font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px}
.metric-value{font-size:26px;font-weight:300;letter-spacing:-0.03em;color:var(--text)}
.metric-sub{font-size:11px;color:var(--text-3);margin-top:5px}
.metric-dot{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:5px;vertical-align:middle}

/* Table container */
.table-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.table-header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--border)}
.table-title{font-size:13px;font-weight:500;color:var(--text)}
.add-btn{font-size:12px;color:var(--blue);background:var(--blue-bg);border:none;border-radius:var(--radius-sm);padding:5px 12px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:opacity 0.15s}
.add-btn:hover{opacity:0.8}
table{width:100%;border-collapse:collapse}
thead th{font-size:11px;font-weight:500;color:var(--text-3);text-transform:uppercase;letter-spacing:0.06em;padding:10px 20px;text-align:left;border-bottom:1px solid var(--border);background:var(--surface2)}
tbody td{padding:12px 20px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:middle}
tbody tr:last-child td{border-bottom:none}
tbody tr:hover td{background:#FAFAF8}

/* Badges */
.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:500}
.b-green{background:var(--green-bg);color:var(--green-text)}
.b-amber{background:var(--amber-bg);color:var(--amber-text)}
.b-red{background:var(--red-bg);color:var(--red-text)}
.b-blue{background:var(--blue-bg);color:var(--blue-text)}
.b-gray{background:var(--gray-bg);color:var(--gray-text)}

/* Progress */
.progress-wrap{display:flex;align-items:center;gap:10px;min-width:120px}
.progress-track{flex:1;height:4px;background:var(--surface2);border-radius:2px;overflow:hidden}
.progress-fill{height:100%;border-radius:2px;transition:width 0.4s}
.p-ok{background:var(--green)}
.p-warn{background:#E09A20}
.p-danger{background:var(--red)}
.progress-pct{font-size:11px;color:var(--text-3);font-family:'DM Mono',monospace;min-width:30px}

/* SLA bar */
.sla-wrap{display:flex;flex-direction:column;gap:5px;min-width:140px}
.sla-track{height:5px;background:var(--surface2);border-radius:3px;overflow:hidden}
.sla-fill{height:100%;border-radius:3px;transition:width 0.4s}

/* Edit form */
.edit-cell{display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:8px 0}
input[type=text],input[type=number],select{font-size:12px;font-family:'DM Sans',sans-serif;padding:5px 10px;border:1px solid var(--border-strong);border-radius:var(--radius-sm);background:var(--surface);color:var(--text);outline:none}
input[type=text]:focus,input[type=number]:focus,select:focus{border-color:var(--text)}
.save-btn{font-size:12px;font-family:'DM Sans',sans-serif;font-weight:500;background:var(--text);color:#FFF;border:none;border-radius:var(--radius-sm);padding:5px 12px;cursor:pointer;transition:opacity 0.15s}
.save-btn:hover{opacity:0.8}
.del-btn{font-size:12px;font-family:'DM Sans',sans-serif;background:none;color:var(--red);border:1px solid var(--red-bg);border-radius:var(--radius-sm);padding:5px 10px;cursor:pointer;transition:all 0.15s}
.del-btn:hover{background:var(--red-bg)}
.edit-btn{font-size:11px;font-family:'DM Sans',sans-serif;background:none;border:1px solid var(--border);border-radius:var(--radius-sm);padding:3px 9px;cursor:pointer;color:var(--text-3);transition:all 0.15s}
.edit-btn:hover{border-color:var(--border-strong);color:var(--text)}

/* KPI cards */
.kpi-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:20px}
.kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px}
.kpi-name{font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px}
.kpi-val-row{display:flex;align-items:baseline;gap:6px;margin-bottom:10px}
.kpi-val{font-size:28px;font-weight:300;letter-spacing:-0.03em}
.kpi-meta{font-size:13px;color:var(--text-3)}
.kpi-footer{display:flex;align-items:center;justify-content:space-between;margin-top:6px}
.kpi-diff{font-size:11px;color:var(--text-3)}

/* Tabs */
.tabs{display:flex;gap:2px;margin-bottom:20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:4px;width:fit-content}
.tab{font-size:13px;font-family:'DM Sans',sans-serif;padding:6px 16px;border:none;background:none;color:var(--text-2);cursor:pointer;border-radius:7px;transition:all 0.15s;font-weight:400}
.tab:hover{color:var(--text)}
.tab.active{background:var(--surface2);color:var(--text);font-weight:500}

/* Responsive */
@media(max-width:900px){
  .layout{grid-template-columns:1fr}
  .sidebar{display:none}
  .main{padding:20px}
  .metrics{grid-template-columns:repeat(2,1fr)}
  .kpi-grid{grid-template-columns:1fr}
}
@media(max-width:600px){.metrics{grid-template-columns:1fr}}
</style>
</head>
<body>

<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="logo">
      <div class="logo-name" id="org-name">Mi organización</div>
      <div class="logo-sub">Panel de operaciones</div>
    </div>
    <span class="nav-section">Vistas</span>
    <div class="nav-item active" onclick="showTab('proyectos');setActive(this)">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="5" height="5" rx="1"/><rect x="9" y="2" width="5" height="5" rx="1"/><rect x="2" y="9" width="5" height="5" rx="1"/><rect x="9" y="9" width="5" height="5" rx="1"/></svg>
      Proyectos
    </div>
    <div class="nav-item" onclick="showTab('sla');setActive(this)">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><polyline points="8,5 8,8 10,10"/></svg>
      SLA
    </div>
    <div class="nav-item" onclick="showTab('kpis');setActive(this)">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="2,12 6,7 9,10 14,4"/></svg>
      KPIs
    </div>
    <div class="nav-item" onclick="showTab('tareas');setActive(this)">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="4" y1="5" x2="12" y2="5"/><line x1="4" y1="8" x2="12" y2="8"/><line x1="4" y1="11" x2="8" y2="11"/></svg>
      Tareas
    </div>
    <div class="sidebar-footer">
      <div class="clock-display" id="clock">--/--/---- --:--</div>
    </div>
  </aside>

  <!-- Main content -->
  <main class="main">
    <div class="page-header">
      <div>
        <div class="page-title">Tablero de operaciones</div>
        <div class="page-sub">Monitoreo de iniciativas y procesos del área</div>
      </div>
    </div>

    <!-- Metrics -->
    <div class="metrics" id="metrics-grid"></div>

    <!-- Tabs (mobile) -->
    <div class="tabs" style="display:none" id="mobile-tabs">
      <button class="tab active" onclick="showTab('proyectos')">Proyectos</button>
      <button class="tab" onclick="showTab('sla')">SLA</button>
      <button class="tab" onclick="showTab('kpis')">KPIs</button>
      <button class="tab" onclick="showTab('tareas')">Tareas</button>
    </div>

    <!-- Proyectos -->
    <div id="tab-proyectos">
      <div class="table-wrap">
        <div class="table-header">
          <span class="table-title">Proyectos activos</span>
          <button class="add-btn" onclick="addRow('proyectos')">+ Agregar proyecto</button>
        </div>
        <table><thead><tr><th>Proyecto</th><th>Responsable</th><th>Estado</th><th>Progreso</th><th>Vencimiento</th><th></th></tr></thead>
        <tbody id="tbody-proyectos"></tbody></table>
      </div>
    </div>

    <!-- SLA -->
    <div id="tab-sla" style="display:none">
      <div class="table-wrap">
        <div class="table-header">
          <span class="table-title">SLA / tiempos de respuesta</span>
          <button class="add-btn" onclick="addRow('sla')">+ Agregar proceso</button>
        </div>
        <table><thead><tr><th>Proceso</th><th>SLA objetivo (hs)</th><th>Tiempo actual (hs)</th><th>Estado</th><th></th></tr></thead>
        <tbody id="tbody-sla"></tbody></table>
      </div>
    </div>

    <!-- KPIs -->
    <div id="tab-kpis" style="display:none">
      <div class="kpi-grid" id="kpi-grid"></div>
      <div class="table-wrap">
        <div class="table-header">
          <span class="table-title">Detalle de indicadores</span>
          <button class="add-btn" onclick="addRow('kpis')">+ Agregar KPI</button>
        </div>
        <table><thead><tr><th>Indicador</th><th>Meta</th><th>Actual</th><th>Período</th><th>Estado</th><th></th></tr></thead>
        <tbody id="tbody-kpis"></tbody></table>
      </div>
    </div>

    <!-- Tareas -->
    <div id="tab-tareas" style="display:none">
      <div class="table-wrap">
        <div class="table-header">
          <span class="table-title">Tareas del equipo</span>
          <button class="add-btn" onclick="addRow('tareas')">+ Agregar tarea</button>
        </div>
        <table><thead><tr><th>Tarea</th><th>Asignado a</th><th>Prioridad</th><th>Proyecto</th><th>Estado</th><th></th></tr></thead>
        <tbody id="tbody-tareas"></tbody></table>
      </div>
    </div>
  </main>
</div>

<script>
const state={
  proyectos:[
    {id:1,nombre:"Rediseño proceso onboarding",resp:"Carla M.",estado:"En curso",progreso:65,vto:"2025-06-15"},
    {id:2,nombre:"Implementación nueva plataforma",resp:"Nicolás T.",estado:"En curso",progreso:30,vto:"2025-07-30"},
    {id:3,nombre:"Auditoría interna Q2",resp:"Valentina R.",estado:"Completado",progreso:100,vto:"2025-04-20"},
    {id:4,nombre:"Plan de capacitación equipo",resp:"Carla M.",estado:"En riesgo",progreso:20,vto:"2025-05-10"}
  ],
  sla:[
    {id:1,proceso:"Atención de consultas internas",objetivo:24,actual:18},
    {id:2,proceso:"Respuesta a solicitudes de RRHH",objetivo:48,actual:52},
    {id:3,proceso:"Cierre de tickets operativos",objetivo:72,actual:40},
    {id:4,proceso:"Aprobación de documentos",objetivo:8,actual:11}
  ],
  kpis:[
    {id:1,indicador:"NPS del área",meta:70,actual:74,periodo:"Q2 2025",estado:"OK"},
    {id:2,indicador:"Proyectos a tiempo",meta:90,actual:75,periodo:"Abril 2025",estado:"Riesgo"},
    {id:3,indicador:"Satisfacción del equipo",meta:80,actual:82,periodo:"Q1 2025",estado:"OK"},
    {id:4,indicador:"Cumplimiento de SLA",meta:95,actual:88,periodo:"Abril 2025",estado:"Riesgo"}
  ],
  tareas:[
    {id:1,tarea:"Revisar propuesta proveedor",asignado:"Nicolás T.",prioridad:"Alta",proyecto:"Nueva plataforma",estado:"Pendiente"},
    {id:2,tarea:"Enviar informe mensual",asignado:"Carla M.",prioridad:"Alta",proyecto:"Auditoría Q2",estado:"En curso"},
    {id:3,tarea:"Actualizar cronograma",asignado:"Valentina R.",prioridad:"Media",proyecto:"Onboarding",estado:"Pendiente"},
    {id:4,tarea:"Coordinar reunión kick-off",asignado:"Nicolás T.",prioridad:"Baja",proyecto:"Capacitación",estado:"Completado"},
    {id:5,tarea:"Documentar proceso nuevo",asignado:"Carla M.",prioridad:"Media",proyecto:"Nueva plataforma",estado:"Pendiente"}
  ]
};

const estadoC={
  "En curso":"b-blue","Completado":"b-green","En riesgo":"b-red","Pausado":"b-gray",
  "Pendiente":"b-amber","OK":"b-green","Riesgo":"b-amber","Crítico":"b-red"
};
const prioC={"Alta":"b-red","Media":"b-amber","Baja":"b-gray"};

function badge(t,map){return`<span class="badge ${map[t]||'b-gray'}">${t}</span>`}

function progressBar(pct){
  const c=pct>=80?"p-ok":pct>=50?"p-warn":"p-danger";
  return`<div class="progress-wrap"><div class="progress-track"><div class="progress-fill ${c}" style="width:${pct}%"></div></div><span class="progress-pct">${pct}%</span></div>`;
}

function slaBar(obj,act){
  const ratio=act/obj;
  const pct=Math.min(100,Math.round(ratio*100));
  let color=ratio>1?"#A32D2D":ratio>0.85?"#E09A20":"#2D6A4F";
  const lbl=ratio<=1?`<span class="badge b-green">Cumplido (${act}/${obj} hs)</span>`:`<span class="badge b-red">Excedido (${act}/${obj} hs)</span>`;
  return`<div class="sla-wrap">${lbl}<div class="sla-track"><div class="sla-fill" style="width:${pct}%;background:${color}"></div></div></div>`;
}

function formatDate(d){if(!d)return"—";const[y,m,day]=d.split("-");return`${day}/${m}/${y}`}

function renderProyectos(){
  document.getElementById("tbody-proyectos").innerHTML=state.proyectos.map(p=>`
    <tr><td>${p.nombre}</td><td style="color:var(--text-2)">${p.resp}</td><td>${badge(p.estado,estadoC)}</td>
    <td>${progressBar(p.progreso)}</td>
    <td style="font-family:'DM Mono',monospace;font-size:12px;color:var(--text-3)">${formatDate(p.vto)}</td>
    <td><button class="edit-btn" onclick="editRow('proyectos',${p.id})">editar</button></td></tr>`).join("");
}

function renderSLA(){
  document.getElementById("tbody-sla").innerHTML=state.sla.map(s=>`
    <tr><td>${s.proceso}</td>
    <td style="font-family:'DM Mono',monospace;text-align:center">${s.objetivo}</td>
    <td style="font-family:'DM Mono',monospace;text-align:center">${s.actual}</td>
    <td>${slaBar(s.objetivo,s.actual)}</td>
    <td><button class="edit-btn" onclick="editRow('sla',${s.id})">editar</button></td></tr>`).join("");
}

function renderKPIs(){
  document.getElementById("tbody-kpis").innerHTML=state.kpis.map(k=>`
    <tr><td>${k.indicador}</td>
    <td style="font-family:'DM Mono',monospace">${k.meta}</td>
    <td style="font-family:'DM Mono',monospace;font-weight:500">${k.actual}</td>
    <td style="color:var(--text-3);font-size:12px">${k.periodo}</td>
    <td>${badge(k.estado,estadoC)}</td>
    <td><button class="edit-btn" onclick="editRow('kpis',${k.id})">editar</button></td></tr>`).join("");

  document.getElementById("kpi-grid").innerHTML=state.kpis.map(k=>{
    const pct=Math.min(Math.round((k.actual/k.meta)*100),100);
    const diff=k.actual-k.meta;
    const diffStr=diff>=0?`<span style="color:var(--green)">+${diff} vs meta</span>`:`<span style="color:var(--red)">${diff} vs meta</span>`;
    const c=pct>=100?"p-ok":pct>=85?"p-warn":"p-danger";
    return`<div class="kpi-card">
      <div class="kpi-name">${k.indicador}</div>
      <div class="kpi-val-row"><span class="kpi-val">${k.actual}</span><span class="kpi-meta">/ ${k.meta}</span></div>
      <div class="progress-wrap" style="margin-bottom:8px"><div class="progress-track" style="flex:1"><div class="progress-fill ${c}" style="width:${pct}%"></div></div><span class="progress-pct">${pct}%</span></div>
      <div class="kpi-footer"><span class="kpi-diff">${diffStr}</span><span style="font-size:11px;color:var(--text-3)">${k.periodo}</span></div>
    </div>`;
  }).join("");
}

function renderTareas(){
  document.getElementById("tbody-tareas").innerHTML=state.tareas.map(t=>`
    <tr><td>${t.tarea}</td><td style="color:var(--text-2)">${t.asignado}</td>
    <td>${badge(t.prioridad,prioC)}</td>
    <td style="color:var(--text-3);font-size:12px">${t.proyecto}</td>
    <td>${badge(t.estado,estadoC)}</td>
    <td><button class="edit-btn" onclick="editRow('tareas',${t.id})">editar</button></td></tr>`).join("");
}

function renderMetrics(){
  const total=state.proyectos.length;
  const activos=state.proyectos.filter(p=>p.estado==="En curso").length;
  const riesgo=state.proyectos.filter(p=>p.estado==="En riesgo").length;
  const slaOk=state.sla.filter(s=>s.actual<=s.objetivo).length;
  const slaPct=Math.round((slaOk/state.sla.length)*100);
  const tareasPend=state.tareas.filter(t=>t.estado==="Pendiente").length;
  const kpiOk=state.kpis.filter(k=>k.estado==="OK").length;
  document.getElementById("metrics-grid").innerHTML=`
    <div class="metric"><div class="metric-label">Proyectos activos</div><div class="metric-value">${activos}</div><div class="metric-sub"><span class="metric-dot" style="background:var(--red)"></span>${riesgo} en riesgo · ${total} total</div></div>
    <div class="metric"><div class="metric-label">Cumplimiento SLA</div><div class="metric-value">${slaPct}%</div><div class="metric-sub">${slaOk} de ${state.sla.length} procesos OK</div></div>
    <div class="metric"><div class="metric-label">KPIs en meta</div><div class="metric-value">${kpiOk}<span style="font-size:16px;font-weight:400;color:var(--text-3)">/${state.kpis.length}</span></div><div class="metric-sub">Indicadores del período</div></div>
    <div class="metric"><div class="metric-label">Tareas pendientes</div><div class="metric-value">${tareasPend}</div><div class="metric-sub">De ${state.tareas.length} tareas totales</div></div>`;
}

function renderAll(){renderMetrics();renderProyectos();renderSLA();renderKPIs();renderTareas();}

function showTab(name){
  ["proyectos","sla","kpis","tareas"].forEach(t=>{
    document.getElementById("tab-"+t).style.display=t===name?"block":"none";
  });
  document.querySelectorAll(".nav-item").forEach(el=>{
    const txt=el.textContent.trim().toLowerCase();
    el.classList.toggle("active",txt===name);
  });
}

function setActive(el){
  document.querySelectorAll(".nav-item").forEach(n=>n.classList.remove("active"));
  el.classList.add("active");
}

function editRow(type,id){
  const arr=state[type];
  const item=arr.find(x=>x.id===id);
  if(!item)return;
  let form="";
  if(type==="proyectos"){
    form=`<input type="text" id="ef-nombre" value="${item.nombre}" style="min-width:150px">
    <select id="ef-estado"><option ${item.estado==="En curso"?"selected":""}>En curso</option><option ${item.estado==="Completado"?"selected":""}>Completado</option><option ${item.estado==="En riesgo"?"selected":""}>En riesgo</option><option ${item.estado==="Pausado"?"selected":""}>Pausado</option></select>
    <input type="text" id="ef-resp" value="${item.resp}" style="width:100px" placeholder="Responsable">
    <input type="number" id="ef-progreso" value="${item.progreso}" min="0" max="100" style="width:60px"> %
    <input type="text" id="ef-vto" value="${item.vto}" style="width:110px" placeholder="YYYY-MM-DD">`;
  } else if(type==="sla"){
    form=`<span style="font-size:12px;color:var(--text-2)">${item.proceso}</span>
    <input type="number" id="ef-objetivo" value="${item.objetivo}" style="width:70px"> hs objetivo
    <input type="number" id="ef-actual" value="${item.actual}" style="width:70px"> hs actual`;
  } else if(type==="kpis"){
    form=`<input type="text" id="ef-indicador" value="${item.indicador}" style="width:160px">
    <input type="number" id="ef-meta" value="${item.meta}" style="width:70px"> meta
    <input type="number" id="ef-actual" value="${item.actual}" style="width:70px"> actual
    <input type="text" id="ef-periodo" value="${item.periodo}" style="width:100px" placeholder="Período">`;
  } else if(type==="tareas"){
    form=`<input type="text" id="ef-tarea" value="${item.tarea}" style="min-width:150px">
    <input type="text" id="ef-asignado" value="${item.asignado}" style="width:100px" placeholder="Asignado a">
    <select id="ef-estado"><option ${item.estado==="Pendiente"?"selected":""}>Pendiente</option><option ${item.estado==="En curso"?"selected":""}>En curso</option><option ${item.estado==="Completado"?"selected":""}>Completado</option></select>
    <select id="ef-prio"><option ${item.prioridad==="Alta"?"selected":""}>Alta</option><option ${item.prioridad==="Media"?"selected":""}>Media</option><option ${item.prioridad==="Baja"?"selected":""}>Baja</option></select>`;
  }
  const tbody=document.getElementById("tbody-"+type);
  const idx=arr.findIndex(x=>x.id===id);
  tbody.querySelectorAll("tr")[idx].innerHTML=`<td colspan="5"><div class="edit-cell">${form}<button class="save-btn" onclick="saveRow('${type}',${id})">Guardar</button><button class="del-btn" onclick="deleteRow('${type}',${id})">Eliminar</button></div></td><td></td>`;
}

function saveRow(type,id){
  const item=state[type].find(x=>x.id===id);
  if(!item)return;
  if(type==="proyectos"){
    item.nombre=document.getElementById("ef-nombre").value||item.nombre;
    item.resp=document.getElementById("ef-resp").value||item.resp;
    item.estado=document.getElementById("ef-estado").value;
    item.progreso=Math.min(100,Math.max(0,parseInt(document.getElementById("ef-progreso").value)||0));
    item.vto=document.getElementById("ef-vto").value||item.vto;
  } else if(type==="sla"){
    item.objetivo=parseFloat(document.getElementById("ef-objetivo").value)||item.objetivo;
    item.actual=parseFloat(document.getElementById("ef-actual").value)||item.actual;
  } else if(type==="kpis"){
    item.indicador=document.getElementById("ef-indicador").value||item.indicador;
    item.meta=parseFloat(document.getElementById("ef-meta").value)||item.meta;
    item.actual=parseFloat(document.getElementById("ef-actual").value)||item.actual;
    item.periodo=document.getElementById("ef-periodo").value||item.periodo;
    item.estado=item.actual>=item.meta?"OK":item.actual>=item.meta*0.85?"Riesgo":"Crítico";
  } else if(type==="tareas"){
    item.tarea=document.getElementById("ef-tarea").value||item.tarea;
    item.asignado=document.getElementById("ef-asignado").value||item.asignado;
    item.estado=document.getElementById("ef-estado").value;
    item.prioridad=document.getElementById("ef-prio").value;
  }
  renderAll();
}

function deleteRow(type,id){state[type]=state[type].filter(x=>x.id!==id);renderAll();}

let nextId=200;
function addRow(type){
  nextId++;
  if(type==="proyectos") state.proyectos.push({id:nextId,nombre:"Nuevo proyecto",resp:"—",estado:"En curso",progreso:0,vto:""});
  else if(type==="sla") state.sla.push({id:nextId,proceso:"Nuevo proceso",objetivo:24,actual:0});
  else if(type==="kpis") state.kpis.push({id:nextId,indicador:"Nuevo KPI",meta:100,actual:0,periodo:"—",estado:"Riesgo"});
  else if(type==="tareas") state.tareas.push({id:nextId,tarea:"Nueva tarea",asignado:"—",prioridad:"Media",proyecto:"—",estado:"Pendiente"});
  renderAll();
  setTimeout(()=>editRow(type,nextId),50);
}

function updateClock(){
  document.getElementById("clock").textContent=new Date().toLocaleString("es-AR",{day:"2-digit",month:"2-digit",year:"numeric",hour:"2-digit",minute:"2-digit"});
}

// Responsive tabs
function checkMobile(){
  const isMobile=window.innerWidth<=900;
  document.getElementById("mobile-tabs").style.display=isMobile?"flex":"none";
}
window.addEventListener("resize",checkMobile);
checkMobile();

renderAll();
updateClock();
setInterval(updateClock,30000);
</script>
</body>
</html>
